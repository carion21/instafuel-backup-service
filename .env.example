# === Connexion PostgreSQL (utilisateur read-only dédié) ===
PGHOST=viaduct.proxy.rlwy.net
PGPORT=48229
PGDATABASE=railway
PGUSER=instafuel_backup
PGPASSWORD=***remplacer-par-mot-de-passe-readonly***

# === MinIO (accès limité au bucket backups) ===
MINIO_ENDPOINT=minio-api.beta.geasscorp.com
MINIO_ACCESS_KEY=***remplacer***
MINIO_SECRET_KEY=***remplacer***
MINIO_BUCKET=backups

# === Mode de backup ===
# hourly = toutes les heures, retention 6h glissantes (cron: 5 * * * *)
# daily  = minuit uniquement,  retention 30 jours      (cron: 0 0 * * *)
BACKUP_MODE=hourly

# === Environnement (défini automatiquement par Railway) ===
# NODE_ENV=production
